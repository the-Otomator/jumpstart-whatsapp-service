PORT=3001
# Hostname Traefik routes to this service (compose only; must match DNS)
WA_HOST=wa.otomator.pro
API_SECRET=change_this_to_a_random_secret_32chars
PARTNER_REGISTRATION_KEY=generate-a-strong-secret-here
# Comma-separated explicit origins (exact match). Wildcard patterns for
# *.workmatch.space, *.otomator.co.il, and localhost are built-in — no need to list those here.
ALLOWED_ORIGINS=https://hub.jumpstart.co.il
LOG_LEVEL=info
NODE_ENV=production
SUPABASE_URL=https://mzalzjtsyrjycaxolldv.supabase.co
SUPABASE_SERVICE_KEY=                              # Get from Supabase Dashboard → Settings → API → service_role key
# Bearer secret attached as `Authorization: Bearer <...>` on every outbound webhook POST.
# The receiver (Supabase EF wa-webhook) verifies this. Rotate by updating both sides in lockstep.
WEBHOOK_OUTBOUND_SECRET=change_this_to_a_random_secret_32chars
